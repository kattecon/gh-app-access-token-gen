{
    "name": "gh-app-access-token-gen",
    "type": "module",
    "dependencies": {
        "@actions/core": "3.0.1",
        "@actions/github": "9.1.1",
        "@octokit/auth-app": "8.2.0"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@typescript-eslint/eslint-plugin": "8.60.0",
        "@typescript-eslint/parser": "8.60.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-import-resolver-typescript": "4.4.5",
        "eslint-plugin-import-x": "4.16.2",
        "@types/node": "25.9.2",
        "eslint": "10.4.1",
        "esbuild": "0.28.1",
        "husky": "9.1.7",
        "prettier": "3.8.4",
        "lint-staged": "17.0.7",
        "typescript": "6.0.3",
        "typescript-eslint": "8.60.1"
    },
    "scripts": {
        "prepare": "husky",
        "build": "npm run build-common -- --outfile=dist/index.mjs",
        "build-watch": "npm run build-common -- --watch --outfile=temp/build.js",
        "build-common": "esbuild src/index.ts --banner:js='import { createRequire } from \"node:module\";const require = createRequire(import.meta.url);' --platform=node --format=esm --target=es2023 --bundle",
        "lint": "tsc && eslint src --max-warnings 0 --report-unused-disable-directives && prettier --check 'src/**/*.ts'"
    },
    "lint-staged": {
        "*": "prettier --write"
    }
}
